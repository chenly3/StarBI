# StarBI Docker Compose 环境变量模板
# 复制为 .env 后按服务器实际情况修改。

STARBI_HTTP_PORT=9080
APISIX_ADMIN_PORT=9180

STARBI_PUBLIC_URL=http://服务器IP:9080
SQLBOT_CORS_ORIGINS=http://服务器IP:9080,http://127.0.0.1:9080
SQLBOT_API_BASE=http://starbi-sqlbot:8000/api/v1
STARBI_SQLBOT_DOMAIN=http://starbi-sqlbot:8000
STARBI_SQLBOT_ASSISTANT_ID=1
STARBI_SQLBOT_ASSISTANT_SECRET=请修改为随机长密钥
STARBI_SQLBOT_ENABLED=true

MYSQL_ROOT_PASSWORD=请修改为强密码
POSTGRES_PASSWORD=请修改为强密码
REDIS_PASSWORD=请修改为强密码

SQLBOT_SECRET_KEY=请修改为随机长密钥
SQLBOT_DEFAULT_PWD=请修改为初始密码

EMBEDDING_PROVIDER=local
DEFAULT_EMBEDDING_MODEL=iic/nlp_gte_sentence-embedding_chinese-base
